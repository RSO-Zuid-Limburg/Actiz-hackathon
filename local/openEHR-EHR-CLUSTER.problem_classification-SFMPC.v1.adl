	openEHR-EHR-CLUSTER.problem_classification-SFMPC.v1
specialize
	openEHR-EHR-CLUSTER.problem_classification.v1

concept
	[at0000.1]

language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nl"] = <
			language = <[ISO_639-1::nl]>
			author = <
				["name"] = <"Eline Brader">
				["organisation"] = <"Nedap Healthcare">
