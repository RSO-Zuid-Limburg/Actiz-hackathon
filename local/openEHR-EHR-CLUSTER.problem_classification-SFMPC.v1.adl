			>
		>
	>

description
	original_author = <
		["name"] = <"Joost Holslag">
		["organisation"] = <"Nedap Healtcare">
		["email"] = <"joost.holslag@nedap.com">
	>
	lifecycle_state = <"in_development">
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"For classifying a problem by capturing a domain according to SFMPC.">
		>
		["nl"] = <
			language = <[ISO_639-1::nl]>
			purpose = <"Voor het classificeren van een probleem door het vastleggen van een domein volgens SFMPC.">
		>
	>
	other_details = <
		["MD5-CAM-1.0.1"] = <"5a278472cdf48cbedd8338544ff64027">
		["build_uid"] = <"b0535d4c-652d-3eb8-a8df-c0e580a495ff">
	>

definition
	CLUSTER[at0000.1] matches {    -- SFMPC classification
		items cardinality matches {1..*; unordered} matches {
			ELEMENT[at0001.1] matches {    -- SFMPC domains
				value matches {
					DV_CODED_TEXT matches {
						defining_code matches {
							[local::
							at0.3,    -- S
							at0.4,    -- F
							at0.5,    -- M
							at0.6,    -- P
							at0.7]    -- C
						}
					}
				}
			}
		}
	}

