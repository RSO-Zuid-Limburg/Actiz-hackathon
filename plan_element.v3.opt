                                <archetype_id>
                                    <value>openEHR-EHR-EVALUATION.goal.v1</value>
                                </archetype_id>
                                <term_definitions code="at0000">
                                    <items id="text">Doel</items>
                                    <items id="description">A desired health, or well-being, outcome for the subject of care.</items>
                                </term_definitions>
                                <term_definitions code="at0001">
                                    <items id="text">Tree</items>
                                    <items id="description">@ internal @</items>
                                </term_definitions>
                                <term_definitions code="at0002">
                                    <items id="text">Doel</items>
                                    <items id="description">The name of the desired health outcome.</items>
                                    <items id="comment">For example: reduced blood pressure; 10 kilogram weight loss; or diabetes control.</items>
                                </term_definitions>
                                <term_definitions code="at0003">
                                    <items id="text">Goal proposed date</items>
                                    <items id="description">The desired or proposed date for achieving the goal.</items>
                                </term_definitions>
                                <term_definitions code="at0004">
                                    <items id="text">Goal end date</items>
                                    <items id="description">The actual date that the goal was achieved or abandoned.</items>
                                </term_definitions>
                                <term_definitions code="at0005">
                                    <items id="text">Target</items>
                                    <items id="description">Detail about the intended target.</items>
                                    <items id="comment">Multiple targets are allowed. In some situations, only one target will be required. In some clinical scenarios the goal may require a multifaceted approach with a number of targets contributing to a successful goal outcome. In addition, some goals may require incremental targets to be set sequentially during a period of time.</items>
                                </term_definitions>
                                <term_definitions code="at0006">
                                    <items id="text">Target path</items>
                                    <items id="description">The archetype and path to the node for target data.</items>
                                    <items id="comment">For example: the 'Weight' data element in the OBSERVATION.body_weight archetype.</items>
                                </term_definitions>
                                <term_definitions code="at0007">
                                    <items id="text">Target</items>
                                    <items id="description">The intended target.</items>
                                </term_definitions>
                                <term_definitions code="at0008">
                                    <items id="text">Target proposed date</items>
                                    <items id="description">The desired or proposed date for achieving the target.</items>
                                </term_definitions>
                                <term_definitions code="at0009">
                                    <items id="text">Target end date</items>
                                    <items id="description">The actual date that the target was achieved or abandoned.</items>
                                </term_definitions>
                                <term_definitions code="at0010">
                                    <items id="text">Clinical indication</items>
                                    <items id="description">Name of the problem or diagnosis which is intended to be impacted by achievement of this goal.</items>
                                    <items id="comment">For example: Hypertension; Obesity; or Diabetes Type 2.</items>
                                </term_definitions>
                                <term_definitions code="at0011">
                                    <items id="text">Target name</items>
                                    <items id="description">Identification of the intended target, by name.</items>
                                    <items id="comment">For example: systolic blood pressure under 140 mmHg; lose 10 kilograms; or HBA1c in the normal range.</items>
                                </term_definitions>
                                <term_definitions code="at0012">
                                    <items id="text">Doelbeschrijving</items>
                                    <items id="description">A narrative description of the goal, including target/s to be achieved if relevant.</items>
                                </term_definitions>
                                <term_definitions code="at0013">
                                    <items id="text">Goal outcome</items>
                                    <items id="description">Single word, phrase or brief description which represents the outcome actually achieved for the goal.</items>
                                    <items id="comment">Coding with a terminology is preferred, where possible. For example: target weight achieved; poor diabetes control; or successful completion.</items>
                                </term_definitions>
                                <term_definitions code="at0015">
                                    <items id="text">Achieved</items>
                                    <items id="description">The proposed goal was realised.</items>
                                </term_definitions>
                                <term_definitions code="at0016">
                                    <items id="text">Partially achieved</items>
                                    <items id="description">The proposed goal was partially realised.</items>
                                </term_definitions>
                                <term_definitions code="at0017">
                                    <items id="text">Not achieved</items>
                                    <items id="description">The proposed goal was not realised and abandoned.</items>
                                </term_definitions>
                                <term_definitions code="at0018">
                                    <items id="text">Target outcome</items>
                                    <items id="description">Single word, phrase or brief description which represents the outcome actually achieved for the target.</items>
                                    <items id="comment">Coding with a terminology is preferred, where possible. This data element could represent success or failure, or some state in between when the goal is completed or abandoned/removed from the record. For example: poor blood sugar control, or successful completion.</items>
                                </term_definitions>
                                <term_definitions code="at0019">
                                    <items id="text">Achieved</items>
                                    <items id="description">The target was realised.</items>
                                </term_definitions>
                                <term_definitions code="at0020">
                                    <items id="text">Partially achieved</items>
                                    <items id="description">The target was partially realised.</items>
                                </term_definitions>
                                <term_definitions code="at0021">
                                    <items id="text">Not achieved</items>
                                    <items id="description">The target was not realised and abandoned.</items>
                                </term_definitions>
                                <term_definitions code="at0022">
                                    <items id="text">Goal comment</items>
                                    <items id="description">Additional narrative about the goal not captured in other fields.</items>
                                    <items id="comment">For example: the reason why the goal was not achieved, or a description about how the goal was partially achieved.</items>
                                </term_definitions>
                                <term_definitions code="at0023">
                                    <items id="text">Target comment</items>
                                    <items id="description">Additional narrative about the target not captured in other fields.</items>
                                    <items id="comment">For example: the reason why the target was not achieved, or a description about how the target was partially achieved.</items>
                                </term_definitions>
                                <term_definitions code="at0024">
                                    <items id="text">Target description</items>
                                    <items id="description">Narrative description about the intended target.</items>
                                </term_definitions>
                                <term_definitions code="at0025">
                                    <items id="text">Goal start date</items>
                                    <items id="description">The anticipated or proposed date for commencing work towards the goal.</items>
                                    <items id="comment">Note: this date may not be the date of recording of the goal.</items>
